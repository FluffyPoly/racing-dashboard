#!/bin/bash
# Load environment variables
if [ -f ~/.env ]; then
    set -a
    source ~/.env
    set +a
fi

race_id="$1"

if [ -z "$race_id" ]; then
  echo "Usage: race-feedback 'race_id'"
  exit 1
fi

WS="/home/ruby"
S_URL="https://txsuawougiptdlmmiasy.supabase.co/rest/v1"
S_KEY="${SUPABASE_KEY}"
RACE_DIR="$WS/races/$race_id"

echo "🔄 DB-Driven Feedback Loop initiated for $race_id"

# 1. FETCH PREDICTION AND RESULT FROM SUPABASE
data_json=$(python3 -c "
import requests, json
headers = {'apikey': '$S_KEY', 'Authorization': 'Bearer $S_KEY'}
race = requests.get(f'$S_URL/races?id=eq.$race_id&select=full_data', headers=headers).json()
result = requests.get(f'$S_URL/results?race_id=eq.$race_id&select=winner,full_order', headers=headers).json()

if race and result:
    print(json.dumps({'prediction': race[0]['full_data'], 'outcome': result[0]}))
else:
    print('null')
")

if [ "$data_json" == "null" ] || [ -z "$data_json" ]; then
    echo "❌ Error: DB records not found for $race_id"
    exit 1
fi

prediction_json=$(echo "$data_json" | jq -c .prediction)
results_json=$(echo "$data_json" | jq -c .outcome)

# Buffer results
mkdir -p /home/ruby/tmp
echo "$results_json" > /home/ruby/tmp/results_temp.json

# Generate meaningful learnings from prediction vs actual outcome
generate_learnings() {
  local race_id="$1"
  local prediction_file="$2"
  local results="$3"

  # Use dedicated learnings analyzer for meaningful insights
  python3 /home/ruby/bin/learnings-analyzer.py "$prediction_file" "$results" 2>/dev/null || echo '{"ruby":"Analysis pending","keenan":"Analysis pending","mordin":"Analysis pending"}'
}

# 2. GENERATE AGENT PROMPTS (ROBUST)
prompts=$(python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
p = data['prediction']
o = data['outcome']
winner = o.get('winner', 'Unknown')

# Ruby Prompt
ruby_rankings = p.get('analysis', {}).get('ruby', {}).get('rankings', [])
top_pick = 'None'
if ruby_rankings:
    top_pick = sorted(ruby_rankings, key=lambda x: x.get('win_probability', 0), reverse=True)[0].get('name', 'None')
ruby_p = f\"The race result was: {winner}. Your top pick was {top_pick}. In exactly one professional sentence, what specific factor did you miscalculate?\"

# Keenan Prompt
most_prob = p.get('analysis', {}).get('keenan', {}).get('most_probable_winner', {}).get('horse', 'None')
keenan_p = f\"The race result was: {winner}. Your most probable winner was {most_prob}. In exactly one professional sentence, why was your probability distribution off?\"

# Mordin Prompt
market_comp = p.get('analysis', {}).get('mordin', {}).get('market_comparison', [])
model_prob = 'unknown'
for entry in market_comp:
    if entry.get('horse', '').lower() in winner.lower() or winner.lower() in entry.get('horse', '').lower():
        model_prob = entry.get('model_probability', 'unknown')
        break
mordin_p = f\"The race result was: {winner}. Model probability was {model_prob}. In exactly one professional sentence, how did the market behave relative to our model?\"

print(json.dumps({'ruby': ruby_p, 'keenan': keenan_p, 'mordin': mordin_p}))
" <<< "$data_json")

ruby_prompt=$(echo "$prompts" | jq -r .ruby)
keenan_prompt=$(echo "$prompts" | jq -r .keenan)
mordin_prompt=$(echo "$prompts" | jq -r .mordin)

echo "1. Generating meaningful learnings..."
# Generate real, actionable insights by comparing predictions to actual outcome
learnings_json=$(python3 /home/ruby/bin/learnings-analyzer.py "$prediction_json" "$(cat /home/ruby/tmp/results_temp.json)" 2>/dev/null)

if [ -z "$learnings_json" ]; then
    learnings_json='{"ruby":"Analysis pending","keenan":"Analysis pending","mordin":"Analysis pending"}'
fi

# 2. PUSH FINAL INSIGHTS TO SUPABASE
echo "☁️ Syncing learnings to database..."
python3 -c "
import requests, json, os
try:
    with open('/home/ruby/tmp/results_temp.json', 'r') as f: results = json.load(f)

    learnings = json.loads('''$learnings_json''')

    payload = {
        'race_id': '$race_id',
        'results': results,
        'insights': learnings
    }

    url = 'https://txsuawougiptdlmmiasy.supabase.co/rest/v1/learnings'
    headers = {
        'apikey': '$S_KEY',
        'Authorization': 'Bearer $S_KEY',
        'Content-Type': 'application/json',
        'Prefer': 'resolution=merge-duplicates'
    }
    r = requests.post(url, headers=headers, json=payload)
    print('✅ Learnings synced with meaningful insights')
except Exception as e:
    print(f'❌ Error syncing learnings: {e}')
"

# 3. WINNER DETECTION & TWITTER POST
echo "🏇 Checking for winner match..."
echo "$prediction_json" | python3 -c "
import json, sys
try:
    try:
        pred_data = json.load(sys.stdin)
    except:
        # If stdin parse fails, try reading the argument
        pred_data = json.loads(sys.stdin.read())

    with open('/home/ruby/tmp/results_temp.json', 'r') as f:
        results = json.load(f)

    ruby_rankings = pred_data.get('analysis', {}).get('ruby', {}).get('rankings', [])

    if ruby_rankings:
        top_pick = sorted(ruby_rankings, key=lambda x: x.get('win_probability', 0), reverse=True)[0].get('name', '')
        actual_winner = results.get('winner', '').lower().strip()

        # Normalize for comparison
        top_pick_norm = top_pick.lower().strip()

        if actual_winner and top_pick_norm and actual_winner == top_pick_norm:
            print(f'🎉 WINNER DETECTED: {top_pick} matched actual winner!')
            print(f'trigger_persad_twitter:{top_pick}')
        else:
            print(f'No match: Predicted {top_pick}, Actual {actual_winner}')
    else:
        print('No predictions to compare')
except Exception as e:
    print(f'Error in winner detection: {e}')
" > /tmp/winner_check.txt

# 5. DYNAMIC TWITTER POSTING (Low-cost, varied messages)
echo "📱 Checking for winner to post..."
winner_check=$(cat /tmp/winner_check.txt)
echo "$winner_check" | grep -q "trigger_persad_twitter" && {
    winner_horse=$(echo "$winner_check" | grep "trigger_persad_twitter" | cut -d: -f2 | xargs)

    # Generate context-aware tweet message
    tweet=$(python3 /home/ruby/bin/twitter-message-generator.py "$race_id" "$RACE_DIR" "$winner_horse" 2>/dev/null)

    if [ -z "$tweet" ]; then
        tweet="🏇 $winner_horse wins! Check our Racing Intelligence dashboard: racing-dashboard-murex.vercel.app"
    fi

    # Post to Twitter if authenticated
    if [ -f /home/ruby/.local/bin/twitter ] && /home/ruby/.local/bin/twitter status >/dev/null 2>&1; then
        if /home/ruby/.local/bin/twitter post "$tweet" 2>/dev/null; then
            echo "✅ Posted to X: $winner_horse"
            echo "   Message: $tweet"
        fi
    else
        echo "📝 [WINNER] $winner_horse | Message: $tweet"
    fi
}

# 4. SKIP LEARNINGS SYNC TO SAVE API CREDITS
# Learnings generation disabled temporarily to preserve API budget
# Re-enable when credits are replenished
# echo "📚 Syncing learnings to dashboard..."
# learnings_json=$(python3 /home/ruby/bin/learnings-formatter-v2.py "$race_id" "$RACE_DIR" 2>/dev/null)
# ... syncing code ...
echo "⏭️  Learnings analysis skipped (cost optimization)"

echo "✅ Feedback Loop Complete (Zero-Tolerance)."
